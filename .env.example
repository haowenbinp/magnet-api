# ─── magnet-api 环境变量配置 ───────────────────────────────────────────────────
# 复制此文件为 .env，填入你的 Key
# cp .env.example .env

# 服务端口（默认 3000）
PORT=3000

# ── TMDB API Key (推荐，中文数据丰富) ─────────────────────────────────────────
# 免费注册: https://www.themoviedb.org/settings/api
# 注册后在 API 设置页获取 "API Read Access Token (v3 auth)"
TMDB_API_KEY=59161a9340cdcb0220ae659ae8c1546d

# ── OMDB API Key (可选，作为备用数据源) ──────────────────────────────────────
# 免费注册: https://www.omdbapi.com/apikey.aspx  (每天 1000 次)
OMDB_API_KEY=59161a9340cdcb0220ae659ae8c1546d
